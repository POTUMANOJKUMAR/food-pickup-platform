{
  "info": {
    "name": "Food Pickup Platform - Category & Menu",
    "description": "Examples for category and menu item management endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api/v1" },
    { "key": "accessToken", "value": "" },
    { "key": "restaurantId", "value": "6f7b2d0c-1111-4444-8888-987654321000" },
    { "key": "categoryId", "value": "9fa2b111-2222-4444-8888-123456789000" },
    { "key": "menuItemId", "value": "1b4e8f11-3333-4444-8888-123456789000" }
  ],
  "item": [
    {
      "name": "Create Category",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"restaurantId\": \"{{restaurantId}}\",\n  \"name\": \"Biryani\",\n  \"description\": \"Signature biryani dishes\"\n}"
        },
        "url": "{{baseUrl}}/categories"
      }
    },
    {
      "name": "List Categories",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/categories?page=1&limit=20&search=bir"
      }
    },
    {
      "name": "Get Category",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/categories/{{categoryId}}"
      }
    },
    {
      "name": "Update Category",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Main Course\",\n  \"description\": \"Main course dishes\"\n}"
        },
        "url": "{{baseUrl}}/categories/{{categoryId}}"
      }
    },
    {
      "name": "Delete Category",
      "request": {
        "method": "DELETE",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": "{{baseUrl}}/categories/{{categoryId}}"
      }
    },
    {
      "name": "List Restaurant Categories",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/restaurants/{{restaurantId}}/categories?page=1&limit=20&search=starter"
      }
    },
    {
      "name": "Create Menu Item",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"restaurantId\": \"{{restaurantId}}\",\n  \"categoryId\": \"{{categoryId}}\",\n  \"name\": \"Chicken Biryani\",\n  \"description\": \"Aromatic basmati rice with spiced chicken\",\n  \"price\": 249,\n  \"imageUrl\": \"https://cdn.example.com/menu/chicken-biryani.jpg\",\n  \"isAvailable\": true,\n  \"preparationTime\": 25\n}"
        },
        "url": "{{baseUrl}}/menu-items"
      }
    },
    {
      "name": "List Menu Items",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/menu-items?page=1&limit=20&search=biryani&categoryId={{categoryId}}&isAvailable=true&sortByPrice=asc"
      }
    },
    {
      "name": "Get Menu Item",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/menu-items/{{menuItemId}}"
      }
    },
    {
      "name": "Update Menu Item",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"price\": 279,\n  \"isAvailable\": true,\n  \"preparationTime\": 30\n}"
        },
        "url": "{{baseUrl}}/menu-items/{{menuItemId}}"
      }
    },
    {
      "name": "Delete Menu Item",
      "request": {
        "method": "DELETE",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": "{{baseUrl}}/menu-items/{{menuItemId}}"
      }
    },
    {
      "name": "List Restaurant Menu",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/restaurants/{{restaurantId}}/menu?page=1&limit=20&isAvailable=true&sortByPrice=desc"
      }
    },
    {
      "name": "List Category Menu",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/categories/{{categoryId}}/menu?page=1&limit=20&search=biryani"
      }
    }
  ]
}
