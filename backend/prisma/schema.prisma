generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  RESTAURANT_OWNER
  ADMIN
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY_FOR_PICKUP
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum NotificationType {
  ORDER_CREATED
  ORDER_CONFIRMED
  ORDER_PREPARING
  ORDER_READY_FOR_PICKUP
  ORDER_COMPLETED
  ORDER_CANCELLED
  PAYMENT_SUCCESS
  PAYMENT_FAILED
  NEW_ORDER_RECEIVED
  RESTAURANT_APPROVED
  SYSTEM_NOTIFICATION
}

enum WalletTransactionType {
  CREDIT
  DEBIT
  SETTLEMENT
  COMMISSION
}

enum SettlementStatus {
  PENDING
  APPROVED
  PROCESSING
  PAID
  REJECTED
}

model User {
  id            String         @id @default(uuid()) @db.Uuid
  name          String         @db.VarChar(100)
  email         String         @unique @db.VarChar(255)
  passwordHash  String         @map("password_hash") @db.VarChar(255)
  role          Role           @default(USER)
  isActive      Boolean        @default(true) @map("is_active")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  refreshTokens RefreshToken[]
  restaurants   Restaurant[]   @relation("RestaurantOwner")
  approvals     Restaurant[]   @relation("RestaurantApprover")
  carts         Cart[]
  orders        Order[]
  payments      Payment[]
  notifications Notification[]
  reviews       Review[]

  @@map("users")
}

model Restaurant {
  id           String    @id @default(uuid()) @db.Uuid
  ownerId      String    @map("owner_id") @db.Uuid
  name         String    @db.VarChar(150)
  description  String?   @db.Text
  address      String    @db.Text
  latitude     Decimal   @db.Decimal(9, 6)
  longitude    Decimal   @db.Decimal(9, 6)
  phone        String    @db.VarChar(20)
  openingTime  DateTime  @map("opening_time") @db.Time(0)
  closingTime  DateTime  @map("closing_time") @db.Time(0)
  isActive     Boolean   @default(true) @map("is_active")
  isApproved   Boolean   @default(false) @map("is_approved")
  approvedAt   DateTime? @map("approved_at")
  approvedById String?   @map("approved_by_id") @db.Uuid
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  owner        User      @relation("RestaurantOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  approvedBy   User?     @relation("RestaurantApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  categories   Category[]
  menuItems    MenuItem[]
  carts        Cart[]
  orders       Order[]
  reviews      Review[]
  wallet       RestaurantWallet?
  settlements  Settlement[]
  businessHours BusinessHours[]
  settings     RestaurantSettings?
  media        RestaurantMedia[]

  @@index([ownerId])
  @@index([name])
  @@index([isActive, isApproved])
  @@map("restaurants")
}

model Category {
  id           String     @id @default(uuid()) @db.Uuid
  restaurantId String     @map("restaurant_id") @db.Uuid
  name         String     @db.VarChar(100)
  description  String?    @db.Text
  isActive     Boolean    @default(true) @map("is_active")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Restrict)
  menuItems    MenuItem[]

  @@unique([restaurantId, name])
  @@index([restaurantId])
  @@index([name])
  @@index([isActive])
  @@map("categories")
}

model MenuItem {
  id              String     @id @default(uuid()) @db.Uuid
  restaurantId    String     @map("restaurant_id") @db.Uuid
  categoryId      String     @map("category_id") @db.Uuid
  name            String     @db.VarChar(150)
  description     String?    @db.Text
  price           Decimal    @db.Decimal(10, 2)
  imageUrl        String?    @map("image_url") @db.VarChar(500)
  isAvailable     Boolean    @default(true) @map("is_available")
  preparationTime Int        @map("preparation_time")
  isActive        Boolean    @default(true) @map("is_active")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")
  restaurant      Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Restrict)
  category        Category   @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  cartItems       CartItem[]
  orderItems      OrderItem[]

  @@index([restaurantId])
  @@index([categoryId])
  @@index([name])
  @@index([isActive, isAvailable])
  @@map("menu_items")
}

model Cart {
  id           String     @id @default(uuid()) @db.Uuid
  userId       String     @map("user_id") @db.Uuid
  restaurantId String?    @map("restaurant_id") @db.Uuid
  subtotal     Decimal    @default(0) @db.Decimal(10, 2)
  totalAmount  Decimal    @default(0) @map("total_amount") @db.Decimal(10, 2)
  isActive     Boolean    @default(true) @map("is_active")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  restaurant   Restaurant? @relation(fields: [restaurantId], references: [id], onDelete: Restrict)
  items        CartItem[]

  @@index([userId, isActive])
  @@index([restaurantId])
  @@map("carts")
}

model CartItem {
  id         String   @id @default(uuid()) @db.Uuid
  cartId     String   @map("cart_id") @db.Uuid
  menuItemId String   @map("menu_item_id") @db.Uuid
  quantity   Int
  unitPrice  Decimal  @map("unit_price") @db.Decimal(10, 2)
  subtotal   Decimal  @db.Decimal(10, 2)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  cart       Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Restrict)

  @@unique([cartId, menuItemId])
  @@index([cartId])
  @@index([menuItemId])
  @@map("cart_items")
}

model Order {
  id            String        @id @default(uuid()) @db.Uuid
  orderNumber   String        @unique @map("order_number") @db.VarChar(20)
  userId        String        @map("user_id") @db.Uuid
  restaurantId  String        @map("restaurant_id") @db.Uuid
  status        OrderStatus   @default(PENDING)
  paymentStatus PaymentStatus @default(PENDING) @map("payment_status")
  pickupCode    String        @map("pickup_code") @db.VarChar(20)
  subtotal      Decimal       @db.Decimal(10, 2)
  taxAmount     Decimal       @map("tax_amount") @db.Decimal(10, 2)
  totalAmount   Decimal       @map("total_amount") @db.Decimal(10, 2)
  cancelledAt   DateTime?     @map("cancelled_at")
  paidAt        DateTime?     @map("paid_at")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  user          User          @relation(fields: [userId], references: [id], onDelete: Restrict)
  restaurant    Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Restrict)
  items         OrderItem[]
  payments      Payment[]
  review        Review?
  walletTransactions WalletTransaction[]

  @@index([userId])
  @@index([restaurantId])
  @@index([status])
  @@index([paymentStatus])
  @@map("orders")
}

model Review {
  id           String     @id @default(uuid()) @db.Uuid
  userId       String     @map("user_id") @db.Uuid
  restaurantId String     @map("restaurant_id") @db.Uuid
  orderId      String     @unique @map("order_id") @db.Uuid
  rating       Int
  comment      String?    @db.Text
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  user         User       @relation(fields: [userId], references: [id], onDelete: Restrict)
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Restrict)
  order        Order      @relation(fields: [orderId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([restaurantId])
  @@index([rating])
  @@map("reviews")
}

model RestaurantWallet {
  id               String              @id @default(uuid()) @db.Uuid
  restaurantId     String              @unique @map("restaurant_id") @db.Uuid
  availableBalance Decimal             @default(0) @map("available_balance") @db.Decimal(10, 2)
  pendingBalance   Decimal             @default(0) @map("pending_balance") @db.Decimal(10, 2)
  lifetimeEarnings Decimal             @default(0) @map("lifetime_earnings") @db.Decimal(10, 2)
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")
  restaurant       Restaurant          @relation(fields: [restaurantId], references: [id], onDelete: Restrict)
  transactions     WalletTransaction[]
  settlements      Settlement[]

  @@index([restaurantId])
  @@map("restaurant_wallets")
}

model WalletTransaction {
  id              String                @id @default(uuid()) @db.Uuid
  walletId        String                @map("wallet_id") @db.Uuid
  orderId         String?               @map("order_id") @db.Uuid
  amount          Decimal               @db.Decimal(10, 2)
  transactionType WalletTransactionType @map("transaction_type")
  description     String?               @db.Text
  createdAt       DateTime              @default(now()) @map("created_at")
  wallet          RestaurantWallet      @relation(fields: [walletId], references: [id], onDelete: Cascade)
  order           Order?                @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([walletId, createdAt])
  @@index([orderId])
  @@index([transactionType])
  @@map("wallet_transactions")
}

model Settlement {
  id              String            @id @default(uuid()) @db.Uuid
  restaurantId    String            @map("restaurant_id") @db.Uuid
  walletId        String            @map("wallet_id") @db.Uuid
  amount          Decimal           @db.Decimal(10, 2)
  status          SettlementStatus  @default(PENDING)
  referenceNumber String?           @unique @map("reference_number") @db.VarChar(100)
  remarks         String?           @db.Text
  requestedAt     DateTime          @default(now()) @map("requested_at")
  processedAt     DateTime?         @map("processed_at")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  restaurant      Restaurant        @relation(fields: [restaurantId], references: [id], onDelete: Restrict)
  wallet          RestaurantWallet  @relation(fields: [walletId], references: [id], onDelete: Restrict)

  @@index([restaurantId])
  @@index([walletId])
  @@index([status])
  @@index([requestedAt])
  @@map("settlements")
}

model OrderItem {
  id             String   @id @default(uuid()) @db.Uuid
  orderId        String   @map("order_id") @db.Uuid
  menuItemId     String   @map("menu_item_id") @db.Uuid
  name           String   @db.VarChar(150)
  quantity       Int
  unitPrice      Decimal  @map("unit_price") @db.Decimal(10, 2)
  subtotal       Decimal  @db.Decimal(10, 2)
  createdAt      DateTime @default(now()) @map("created_at")
  order          Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem       MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([menuItemId])
  @@map("order_items")
}

model Payment {
  id                   String        @id @default(uuid()) @db.Uuid
  orderId              String        @map("order_id") @db.Uuid
  userId               String        @map("user_id") @db.Uuid
  amount               Decimal       @db.Decimal(10, 2)
  status               PaymentStatus @default(PENDING)
  razorpayOrderId      String?       @unique @map("razorpay_order_id") @db.VarChar(100)
  razorpayPaymentId    String?       @unique @map("razorpay_payment_id") @db.VarChar(100)
  transactionReference String?       @map("transaction_reference") @db.VarChar(100)
  responsePayload      Json?         @map("response_payload")
  failureReason        String?       @map("failure_reason") @db.Text
  createdAt            DateTime      @default(now()) @map("created_at")
  updatedAt            DateTime      @updatedAt @map("updated_at")
  order                Order         @relation(fields: [orderId], references: [id], onDelete: Restrict)
  user                 User          @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([userId])
  @@index([status])
  @@map("payments")
}

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @map("user_id") @db.Uuid
  title     String           @db.VarChar(150)
  message   String           @db.Text
  type      NotificationType
  isRead    Boolean          @default(false) @map("is_read")
  metadata  Json?
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, isRead])
  @@index([type])
  @@map("notifications")
}

model RefreshToken {
  id        String    @id @db.Uuid
  tokenHash String    @unique @map("token_hash") @db.Char(64)
  userId    String    @map("user_id") @db.Uuid
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model BusinessHours {
  id           String   @id @default(uuid()) @db.Uuid
  restaurantId String   @map("restaurant_id") @db.Uuid
  day          String   @db.VarChar(20)
  openTime     String   @map("open_time") @db.VarChar(10)
  closeTime    String   @map("close_time") @db.VarChar(10)
  isOpen       Boolean  @default(true) @map("is_open")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
  @@map("business_hours")
}

model RestaurantSettings {
  id           String   @id @default(uuid()) @db.Uuid
  restaurantId String   @unique @map("restaurant_id") @db.Uuid
  tagline      String?  @db.VarChar(255)
  cuisine      String?  @db.VarChar(255)
  city         String?  @db.VarChar(100)
  state        String?  @db.VarChar(100)
  pincode      String?  @db.VarChar(20)
  email        String?  @db.VarChar(255)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
  @@map("restaurant_settings")
}

model RestaurantMedia {
  id           String   @id @default(uuid()) @db.Uuid
  restaurantId String   @map("restaurant_id") @db.Uuid
  type         String   @db.VarChar(50)
  url          String   @db.VarChar(500)
  createdAt    DateTime @default(now()) @map("created_at")

  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
  @@map("restaurant_media")
}
