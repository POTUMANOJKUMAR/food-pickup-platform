generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  RESTAURANT_OWNER
  ADMIN
}

model User {
  id            String         @id @default(uuid()) @db.Uuid
  name          String         @db.VarChar(100)
  email         String         @unique @db.VarChar(255)
  passwordHash  String         @map("password_hash") @db.VarChar(255)
  role          Role           @default(USER)
  isActive      Boolean        @default(true) @map("is_active")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  refreshTokens RefreshToken[]
  restaurants   Restaurant[]   @relation("RestaurantOwner")
  approvals     Restaurant[]   @relation("RestaurantApprover")

  @@map("users")
}

model Restaurant {
  id           String    @id @default(uuid()) @db.Uuid
  ownerId      String    @map("owner_id") @db.Uuid
  name         String    @db.VarChar(150)
  description  String?   @db.Text
  address      String    @db.Text
  latitude     Decimal   @db.Decimal(9, 6)
  longitude    Decimal   @db.Decimal(9, 6)
  phone        String    @db.VarChar(20)
  openingTime  DateTime  @map("opening_time") @db.Time(0)
  closingTime  DateTime  @map("closing_time") @db.Time(0)
  isActive     Boolean   @default(true) @map("is_active")
  isApproved   Boolean   @default(false) @map("is_approved")
  approvedAt   DateTime? @map("approved_at")
  approvedById String?   @map("approved_by_id") @db.Uuid
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  owner        User      @relation("RestaurantOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  approvedBy   User?     @relation("RestaurantApprover", fields: [approvedById], references: [id], onDelete: SetNull)

  @@index([ownerId])
  @@index([name])
  @@index([isActive, isApproved])
  @@map("restaurants")
}

model RefreshToken {
  id        String    @id @db.Uuid
  tokenHash String    @unique @map("token_hash") @db.Char(64)
  userId    String    @map("user_id") @db.Uuid
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}
